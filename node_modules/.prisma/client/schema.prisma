// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MAHASISWA
  SATPAM
  ADMIN
}

enum SlotStatus {
  KOSONG
  TERISI
}

enum LogStatus {
  ACTIVE
  COMPLETED
}

model User {
  id            String       @id @default(uuid())
  nim_atau_nidn String       @unique
  nama          String
  email         String       @unique
  password      String
  role          Role
  parking_logs  ParkingLog[]
}

model ParkingSlot {
  id           String       @id @default(uuid())
  slot_code    String       @unique
  status       SlotStatus   @default(KOSONG)
  last_updated DateTime     @updatedAt
  parking_logs ParkingLog[]
}

model ParkingLog {
  id             String    @id @default(uuid())
  user_id        String
  slot_id        String
  check_in_time  DateTime  @default(now())
  check_out_time DateTime?
  status         LogStatus @default(ACTIVE)

  user User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  slot ParkingSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)
}
